{
  "manifest_version": 3,
  "name": "GitHub PR Group",
  "version": "1.0.0",
  "description": "Regroupe automatiquement vos Pull Requests GitHub dans un tab group.",

  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://api.github.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
